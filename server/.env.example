# ════════════════════════════════════════════════════
# AKIRO BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values
# See ENV_SETUP_GUIDE.md for step-by-step instructions
# ════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB Atlas ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/akiro

# ─── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# ─── Cloudinary ────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Google OAuth ──────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Callback URL to register: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ─── GitHub OAuth ──────────────────────────────────────────────
# Get from: https://github.com/settings/developers → OAuth Apps
# Callback URL to register: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Email / SMTP ──────────────────────────────────────────────
# IMPORTANT: EMAIL_PASS is NOT your Gmail password.
# It is a Gmail App Password (16 chars with spaces).
# Generate at: https://myaccount.google.com/apppasswords
# OTP emails are sent dynamically to EVERY user's own email at login time.
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Anthropic AI ──────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
# New accounts get $5 free credit (~1600 resume analyses)
ANTHROPIC_API_KEY=sk-ant-api03-replace_with_real_key
